# DriftLoom Environment Variables
# Copy this file to .env and fill in your values

# RevenueCat API Keys (from app.revenuecat.com → Project Settings → API Keys)
REVENUECAT_IOS_KEY=appl_YOUR_KEY_HERE
REVENUECAT_ANDROID_KEY=goog_YOUR_KEY_HERE

# Anthropic API Key (for AI dream interpretation)
# ⚠️ In production, move this to a backend server!
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# EAS Project ID (from running: eas init)
EAS_PROJECT_ID=YOUR_PROJECT_ID

# Apple Developer (for EAS Submit)
APPLE_ID=jamiebzzz@gmail.com
APPLE_TEAM_ID=YOUR_TEAM_ID
ASC_APP_ID=YOUR_APP_STORE_CONNECT_APP_ID
