{
  "name": "driftloom",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "maestro test .maestro",
